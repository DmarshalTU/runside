{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Runside",
  "version": "0.1.0",
  "identifier": "dev.runside.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/desktop-dev-server.mjs",
    "devUrl": "http://127.0.0.1:8787",
    "beforeBuildCommand": "node ../../scripts/desktop-before-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Runside",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "Local GitHub Actions + Allure report browser",
    "longDescription": "Runside drives GitHub Actions via the gh CLI and opens Allure reports locally.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/runside-server"],
    "resources": {
      "resources/web": "web/",
      "resources/server.cjs": "server.cjs"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
